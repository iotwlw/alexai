{
  "manifest_version": 3,
  "name": "Amazon Rufus信息抓取工具",
  "version": "1.0.0",
  "description": "智能抓取Amazon商品页Ask Rufus提示信息，支持批量URL、断点续传、数据导出",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.ca/dp/*",
        "https://www.amazon.ca/*/dp/*",
        "https://www.amazon.ca/gp/product/*",
        "https://www.amazon.com/dp/*",
        "https://www.amazon.com/*/dp/*",
        "https://www.amazon.com/gp/product/*",
        "https://www.amazon.co.uk/dp/*",
        "https://www.amazon.co.uk/*/dp/*",
        "https://www.amazon.co.uk/gp/product/*",
        "https://www.amazon.de/dp/*",
        "https://www.amazon.de/*/dp/*",
        "https://www.amazon.de/gp/product/*",
        "https://www.amazon.fr/dp/*",
        "https://www.amazon.fr/*/dp/*",
        "https://www.amazon.fr/gp/product/*",
        "https://www.amazon.it/dp/*",
        "https://www.amazon.it/*/dp/*",
        "https://www.amazon.it/gp/product/*",
        "https://www.amazon.es/dp/*",
        "https://www.amazon.es/*/dp/*",
        "https://www.amazon.es/gp/product/*",
        "https://www.amazon.co.jp/dp/*",
        "https://www.amazon.co.jp/*/dp/*",
        "https://www.amazon.co.jp/gp/product/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "https://www.amazon.ca/*",
    "https://www.amazon.com/*",
    "https://www.amazon.co.uk/*",
    "https://www.amazon.de/*",
    "https://www.amazon.fr/*",
    "https://www.amazon.it/*",
    "https://www.amazon.es/*",
    "https://www.amazon.co.jp/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/content.js"],
      "matches": [
        "https://www.amazon.ca/*",
        "https://www.amazon.com/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.de/*",
        "https://www.amazon.fr/*",
        "https://www.amazon.it/*",
        "https://www.amazon.es/*",
        "https://www.amazon.co.jp/*"
      ]
    }
  ]
}
